[Unit]
Description=APEC Quadpod field test app
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/quadpod/flask_app
Environment=QUADPOD_MOCK_HARDWARE=0
Environment=QUADPOD_DATABASE=/opt/quadpod/flask_app/data/quadpod.db
Environment=QUADPOD_VICTOR_NEUTRAL_US=1650
Environment=QUADPOD_VICTOR_PULL_US=1850
Environment=QUADPOD_VICTOR_JOG_US=2004
Environment=QUADPOD_SAMPLE_RATE_HZ=40
Environment=QUADPOD_PRELOAD_MIN_LBS=9.5
Environment=QUADPOD_PRELOAD_MAX_LBS=10.5
Environment=QUADPOD_PRELOAD_AUTO_ABORT_LBS=10.5
Environment=QUADPOD_PRELOAD_STABILITY_SECONDS=4.0
Environment=QUADPOD_PRELOAD_AUTO_TIMEOUT_SECONDS=180
Environment=QUADPOD_PRELOAD_AUTO_SPEED_PERCENT=15
Environment=QUADPOD_PRELOAD_AUTO_SLACK_UNTIL_LBS=0.5
Environment=QUADPOD_PRELOAD_AUTO_SLACK_SPEED_PERCENT=75
Environment=QUADPOD_PRELOAD_AUTO_SLACK_PULSE_SECONDS=0.75
Environment=QUADPOD_PRELOAD_AUTO_COARSE_UNTIL_LBS=3.0
Environment=QUADPOD_PRELOAD_AUTO_COARSE_SPEED_PERCENT=60
Environment=QUADPOD_PRELOAD_AUTO_COARSE_PULSE_SECONDS=0.2
Environment=QUADPOD_PRELOAD_AUTO_APPROACH_UNTIL_LBS=6.0
Environment=QUADPOD_PRELOAD_AUTO_APPROACH_SPEED_PERCENT=45
Environment=QUADPOD_PRELOAD_AUTO_APPROACH_PULSE_SECONDS=0.12
Environment=QUADPOD_PRELOAD_AUTO_SLOW_UNTIL_LBS=8.0
Environment=QUADPOD_PRELOAD_AUTO_SLOW_SPEED_PERCENT=35
Environment=QUADPOD_PRELOAD_AUTO_SLOW_PULSE_SECONDS=0.08
Environment=QUADPOD_PRELOAD_AUTO_FINE_UNTIL_LBS=9.0
Environment=QUADPOD_PRELOAD_AUTO_FINE_SPEED_PERCENT=25
Environment=QUADPOD_PRELOAD_AUTO_FINE_PULSE_SECONDS=0.05
Environment=QUADPOD_PRELOAD_AUTO_MICRO_UNTIL_LBS=9.3
Environment=QUADPOD_PRELOAD_AUTO_MICRO_SPEED_PERCENT=20
Environment=QUADPOD_PRELOAD_AUTO_MICRO_PULSE_SECONDS=0.03
Environment=QUADPOD_PRELOAD_AUTO_PULSE_SECONDS=0.02
Environment=QUADPOD_PRELOAD_AUTO_DOWN_PULSE_SECONDS=0.02
Environment=QUADPOD_PRELOAD_AUTO_SETTLE_SECONDS=6.0
Environment=QUADPOD_PRELOAD_AUTO_SETTLE_MAX_SECONDS=12.0
Environment=QUADPOD_PRELOAD_AUTO_STABLE_WINDOW_SECONDS=2.5
Environment=QUADPOD_PRELOAD_AUTO_STABLE_DELTA_LBS=0.25
Environment=QUADPOD_PULL_DIRECTION=up
Environment=QUADPOD_LOADCELL_REFERENCE_UNIT=10433.64
Environment=QUADPOD_FAILURE_DROP_LBS=12
Environment=QUADPOD_FAILURE_DROP_PERCENT=0.35
Environment=QUADPOD_FAILURE_CONFIRM_SAMPLES=8
Environment=QUADPOD_FAILURE_MIN_PEAK_LBS=20
EnvironmentFile=-/etc/quadpod.env
ExecStart=/opt/quadpod/venv/bin/gunicorn --workers 1 --threads 4 --bind 0.0.0.0:80 --bind 0.0.0.0:5000 app:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
